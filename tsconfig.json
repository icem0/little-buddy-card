{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": ["es2022", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "outDir": "./dist",
    "sourceMap": true,
    "strict": false,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "rootDir": "src",
    "declaration": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
