{
  "name": "little-buddy-card",
  "version": "0.9.3",
  "description": "Gamified Home Assistant Lovelace card with pixel pets and trees",
  "main": "little-buddy-card.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "release": "bash scripts/release.sh",
    "typecheck": "tsc --noEmit",
    "verify": "bash scripts/verify.sh",
    "deploy": "bash scripts/deploy.sh",
    "zip": "python3 scripts/build_release_zip.py"
  },
  "dependencies": {
    "lit": "^3.1.0",
    "puppeteer": "^25.3.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "custom-card-helpers": "^2.0.0",
    "rollup": "^4.9.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}